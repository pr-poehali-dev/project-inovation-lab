{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "me without token returns 401",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401
    },
    {
      "name": "login with unknown nickname returns 403",
      "method": "POST",
      "path": "/?action=login",
      "body": {"nickname": "unknown_user_xyz"},
      "expectedStatus": 403,
      "expectedBody": {"error": "denied"},
      "bodyMatcher": "partial"
    },
    {
      "name": "login with super admin returns token",
      "method": "POST",
      "path": "/?action=login",
      "body": {"nickname": "soul__shu"},
      "expectedStatus": 200,
      "expectedBody": {"role": "super_admin"},
      "bodyMatcher": "partial"
    }
  ]
}